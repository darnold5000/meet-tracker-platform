DATABASE_URL=postgresql://...

# Optional: default meet for legacy HTML index (default MSO-36541).
# GYM_SCORES_MEET_KEY=MSO-36541

# Comma-separated meet_id values for GET /api/meets (must exist in `meets` table).
# Listed meets are returned only if they have scores OR start_date is today/future; optional ?state= filters by meets.state.
# Default in code: MSO-36541
# GYM_SCORES_ALLOWED_MEET_IDS=MSO-36541
