# Local dev (pick ONE):
#
# A) Call FastAPI directly (must match how you open the site: CORS allows :3000 and :3001).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8003
#
# B) Same-origin proxy (no CORS): Next rewrites /api-proxy/* → FastAPI. Restart `npm run dev` after changing.
# NEXT_PUBLIC_API_VIA_PROXY=1
# Optional if API is not on 127.0.0.1:8003: CHEER_API_DEV_PROXY_TARGET=http://127.0.0.1:8003
#
# Production build: set NEXT_PUBLIC_API_URL to your deployed API (no proxy).
# NEXT_PUBLIC_API_URL=https://YOUR-CHEER-SCORES-API.run.app

# Optional: default MVP competition (must exist in cheer_mvp_meets with synced data). Default is CHEERSPORT Atlanta.
# NEXT_PUBLIC_DEFAULT_MEET_KEY=VARSITY-14478875
# NEXT_PUBLIC_DEFAULT_MEET_LABEL=2026 CHEERSPORT National All Star Cheerleading Championship
# NEXT_PUBLIC_DEFAULT_MEET_STATE=GA

# Tally feedback popup: form id from URL path (https://tally.so/r/xxxx → xxxx). Omit to use built-in default.
# NEXT_PUBLIC_TALLY_FEEDBACK_FORM_ID=
