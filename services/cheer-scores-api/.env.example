DATABASE_URL=postgresql://...

# Optional: default meet for legacy HTML index. If unset, first id in CHEER_SCORES_ALLOWED_MEET_IDS is used when non-empty.
# CHEER_SCORES_MEET_KEY=CHEER-MEET-1

# Comma-separated meet_id values for GET /api/meets (must exist in `meets` table).
# CHEER_SCORES_ALLOWED_MEET_IDS=CHEER-MEET-1,CHEER-MEET-2

# Optional: extra CORS origins for the deployed cheer web app (comma-separated).
# Required for custom domains. *.run.app and *.vercel.app are allowed by default unless
# CHEER_SCORES_CORS_NO_RUN_APP_REGEX=1.
# CHEER_SCORES_CORS_ORIGINS=https://your-cheer-domain.com,https://www.your-cheer-domain.com
