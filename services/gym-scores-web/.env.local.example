# Base URL of the FastAPI backend (08 app or deployed Cloud Run Service).
# No trailing slash.
# NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_API_URL="https://gym-scores-api-617613197143.us-central1.run.app"

# Default meet to show when none is selected (optional). Code default is MSO-36541 (2026 IN Optional State; MSO /Results/36541).
# NEXT_PUBLIC_DEFAULT_MEET_KEY=MSO-36541
# Postal/state for that meet — used so the synthetic dropdown row appears when State = IN (not only “All states”). Default IN.
# NEXT_PUBLIC_DEFAULT_MEET_STATE=IN

# Tally feedback popup: form id from URL path (https://tally.so/r/eqE45q → eqE45q). Omit to use built-in default.
# NEXT_PUBLIC_TALLY_FEEDBACK_FORM_ID=eqE45q
